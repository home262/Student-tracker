<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="root" stylesheets="@../css/dashboard.css"
            style="-fx-background-color: transparent; -fx-background: #13110E;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="studenttracker.controller.AttendanceController">
    <content>
        <VBox spacing="30">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <!-- Header -->
            <VBox spacing="5">
                <Label styleClass="header-label" text="THE CODEX" />
                <Label styleClass="title-fantasy" text="Presence Chronicle" />
                <Label styleClass="subtitle-fantasy" text="Your hall sessions — absence breeds dark omens." />
            </VBox>

            <!-- Stats -->
            <HBox spacing="20">
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="PRESENCE RATE" />
                    <Label fx:id="presenceRateLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Overall attendance" />
                </VBox>
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="SESSIONS ATTENDED" />
                    <Label fx:id="presentCountLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Total present" />
                </VBox>
                <VBox prefWidth="200" spacing="8" styleClass="card-omen" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="ABSENCES" />
                    <Label fx:id="absentCountLabel" styleClass="omen-value" text="—" />
                    <Label styleClass="omen-label" text="Sessions missed" />
                </VBox>
            </HBox>

            <!-- Attendance Table -->
            <VBox spacing="15" styleClass="card">
                <Label styleClass="header-label" text="SESSION LOG" />

                <TableView fx:id="attendanceTable"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;"
                           VBox.vgrow="ALWAYS" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="dateCol" text="Date" prefWidth="150" />
                        <TableColumn fx:id="courseCol" text="Course / Quest" prefWidth="250" />
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
