<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane styleClass="root" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <!-- SIDEBAR -->
   <left>
      <VBox prefWidth="250.0" styleClass="sidebar">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <padding>
                  <Insets left="20.0" top="10.0" />
               </padding>
               <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
               </ImageView>
               <VBox>
                  <Label style="-fx-font-size: 16px;" styleClass="sidebar-title" text="Scholar Sanctum..." />
                  <Label style="-fx-font-size: 11px;" styleClass="sidebar-subtitle" text="Spring Semester 2026" />
               </VBox>
            </HBox>
            
            <Region prefHeight="30.0" />
            
            <!-- Main Nav -->
            <Label style="-fx-padding: 0 0 10 20;" styleClass="header-label" text="THE CODEX" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button-active" text="Home Keep">
               <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true" />
               </graphic>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="Grades">
                <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <Image url="@../assets/icons/placeholder.png" />
                  </ImageView>
               </graphic>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="Courses">
                <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <Image url="@../assets/icons/placeholder.png" />
                  </ImageView>
               </graphic>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="Attendance">
                <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <Image url="@../assets/icons/placeholder.png" />
                  </ImageView>
               </graphic>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="Reports">
                <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <Image url="@../assets/icons/placeholder.png" />
                  </ImageView>
               </graphic>
            </Button>

            <Region prefHeight="30.0" />
            
            <!-- Secondary Nav -->
            <Label style="-fx-padding: 0 0 10 20;" styleClass="header-label" text="ARSENAL" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="Export CSV">
                <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <Image url="@../assets/icons/placeholder.png" />
                  </ImageView>
               </graphic>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="AI Advisor">
                <graphic>
                  <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <Image url="@../assets/icons/placeholder.png" />
                  </ImageView>
               </graphic>
            </Button>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <!-- User Profile -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="profile-section">
               <children>
                  <StackPane prefHeight="40.0" prefWidth="40.0">
                     <children>
                        <Circle fill="#4b3d75" radius="20.0" stroke="TRANSPARENT" strokeType="INSIDE" />
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Y" />
                     </children>
                  </StackPane>
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Student Name" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #8b847a;" text="Scholar rank - Steady" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </left>
   
   <!-- MAIN CONTENT -->
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #13110E;" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="30.0">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <!-- Header Area -->
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="header-label" text="SANCTUM OVERVIEW" />
                        <Label styleClass="title-fantasy" text="The Home Keep" />
                        <Label styleClass="subtitle-fantasy" text="A calm command center for honor, presence, and the quests ahead — fed by your ledger." />
                     </children>
                  </VBox>
                  
                  <!-- Stat Cards -->
                  <HBox spacing="20.0">
                     <children>
                        <VBox prefWidth="250.0" spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../assets/icons/placeholder.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="header-label" text="HONOR (GPA)" />
                                 </children>
                              </HBox>
                              <Label styleClass="stat-value" text="3.29" />
                              <Label styleClass="stat-label" text="Weighted across enrolled credits" />
                           </children>
                        </VBox>
                        
                        <VBox prefWidth="250.0" spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../assets/icons/placeholder.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="header-label" text="PRESENCE RATE" />
                                 </children>
                              </HBox>
                              <Label styleClass="stat-value" text="42%" />
                              <Label styleClass="stat-label" style="-fx-text-fill: #e66777;" text="Recover ground in hall sessions" />
                           </children>
                        </VBox>
                        
                        <VBox prefWidth="250.0" spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../assets/icons/placeholder.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="header-label" text="ACTIVE QUESTS" />
                                 </children>
                              </HBox>
                              <Label styleClass="stat-value" text="6" />
                              <Label styleClass="stat-label" text="Spring 2026" />
                           </children>
                        </VBox>
                        
                        <VBox prefWidth="250.0" spacing="10.0" styleClass="card-omen" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../assets/icons/placeholder.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="header-label" text="DARK OMENS" />
                                 </children>
                              </HBox>
                              <Label styleClass="omen-value" text="1" />
                              <Label styleClass="omen-label" text="Courses at or above 3 absences" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Bottom Area (Lists & Actions) -->
                  <HBox spacing="30.0">
                     <children>
                        <!-- Recent Battle Scores List -->
                        <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label styleClass="header-label" text="RECENT BATTLE SCORES" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-text-fill: #8b847a; -fx-font-style: italic; -fx-cursor: hand;" text="View all →" />
                                 </children>
                              </HBox>
                              
                              <!-- Dummy Items -->
                              <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="list-item-card">
                                 <Label style="-fx-text-fill: white;" text="Software Engineering" />
                                 <Label styleClass="badge" text="B+" />
                                 <Label style="-fx-text-fill: #8b847a;" text="88%" />
                              </HBox>
                              
                              <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="list-item-card">
                                 <Label style="-fx-text-fill: white;" text="Computer Networks" />
                                 <Label style="-fx-background-color: #463c27; -fx-text-fill: #d8c28f;" styleClass="badge" text="C+" />
                                 <Label style="-fx-text-fill: #8b847a;" text="76%" />
                              </HBox>
                              
                              <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="list-item-card">
                                 <Label style="-fx-text-fill: white;" text="Algorithms" />
                                 <Label style="-fx-background-color: #273646; -fx-text-fill: #8fb2d8;" styleClass="badge" text="B" />
                                 <Label style="-fx-text-fill: #8b847a;" text="83%" />
                              </HBox>
                           </children>
                        </VBox>
                        
                        <!-- Right Column (Omens & Spells) -->
                        <VBox prefWidth="300.0" spacing="30.0">
                           <children>
                              <!-- Dark Omens Box -->
                              <VBox spacing="15.0" styleClass="card">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <Label styleClass="header-label" text="DARK OMENS" />
                                       <Region HBox.hgrow="ALWAYS" />
                                       <Label style="-fx-text-fill: #8b847a; -fx-font-style: italic; -fx-cursor: hand;" text="View →" />
                                    </HBox>
                                    <VBox style="-fx-background-color: #211113; -fx-border-color: #e66777 transparent transparent transparent; -fx-border-width: 2px 0 0 0; -fx-padding: 10px;">
                                       <children>
                                          <Label style="-fx-text-fill: #e66777; -fx-font-weight: bold;" text="Computer Networks" />
                                          <Label style="-fx-text-fill: #a8a29e; -fx-font-size: 11px;" text="4 absences recorded — stay vigilant" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>
                              
                              <!-- Spells & Actions -->
                              <VBox spacing="15.0">
                                 <children>
                                    <Label styleClass="header-label" text="SPELLS &amp; ACTIONS" />
                                    
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="Forge report scroll">
                                       <graphic>
                                          <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                             <Image url="@../assets/icons/placeholder.png" />
                                          </ImageView>
                                       </graphic>
                                    </Button>
                                    
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="View all grades">
                                       <graphic>
                                          <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                             <Image url="@../assets/icons/placeholder.png" />
                                          </ImageView>
                                       </graphic>
                                    </Button>
                                    
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="Check attendance">
                                       <graphic>
                                          <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                             <Image url="@../assets/icons/placeholder.png" />
                                          </ImageView>
                                       </graphic>
                                    </Button>
                                    
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="Consult the Oracle">
                                       <graphic>
                                          <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                             <Image url="@../assets/icons/placeholder.png" />
                                          </ImageView>
                                       </graphic>
                                    </Button>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
