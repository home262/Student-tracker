<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- We reuse the dashboard.css for global styling -->
<BorderPane styleClass="root" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studenttracker.controller.AdvisorController">
   <!-- The main content area assumes the sidebar is provided by a root layout, but we will make this a full view for simplicity, assuming they swap Center content -->
   <center>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #13110E;" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="30.0">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <!-- Header Area -->
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="header-label" text="THE ORACLE" />
                        <Label styleClass="title-fantasy" text="Consult the AI Advisor" />
                        <Label styleClass="subtitle-fantasy" text="Speak with the Oracle to understand your true standing and receive a quest for the future." />
                     </children>
                  </VBox>
                  
                  <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                     <children>
                        <!-- Main Chat Area -->
                        <VBox spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../assets/icons/placeholder.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="header-label" style="-fx-font-size: 14px; -fx-text-fill: #d4af37;" text="The Oracle Speaks..." />
                                 </children>
                              </HBox>
                              
                              <StackPane VBox.vgrow="ALWAYS">
                                 <children>
                                    <TextArea fx:id="oracleTextArea" editable="false" prefHeight="400.0" style="-fx-control-inner-background: #13110E; -fx-background-color: #13110E; -fx-text-fill: #a8a29e; -fx-font-family: 'Inter', sans-serif; -fx-font-size: 14px; -fx-border-color: #2d251f; -fx-border-radius: 5px; -fx-padding: 10px;" text="The Oracle awaits your inquiry. Press the button below to summon wisdom." wrapText="true" />
                                    <ProgressIndicator fx:id="loadingIndicator" visible="false" />
                                 </children>
                              </StackPane>
                              
                              <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                 <children>
                                    <Label style="-fx-text-fill: #8b847a; -fx-font-size: 11px;" text="Powered by Gemini AI" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button mnemonicParsing="false" onAction="#handleSummonWisdom" style="-fx-background-color: #d4af37; -fx-text-fill: #13110E; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Summon Wisdom" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        
                        <!-- Right Info Box -->
                        <VBox prefWidth="300.0" spacing="20.0">
                           <children>
                              <VBox spacing="15.0" styleClass="card">
                                 <children>
                                    <Label styleClass="header-label" text="HOW IT WORKS" />
                                    <Label style="-fx-text-fill: #a8a29e; -fx-font-size: 12px;" text="The Oracle analyzes your Honor (GPA), recent battle scores, and presence rate." wrapText="true" />
                                    <Label style="-fx-text-fill: #a8a29e; -fx-font-size: 12px;" text="It will weave this data into a personalized scroll, outlining your current path and providing quests to improve your standing." wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
