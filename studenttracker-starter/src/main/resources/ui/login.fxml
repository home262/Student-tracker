<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane styleClass="root" stylesheets="@../css/login.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="studenttracker.controller.LoginController">

    <!-- Background decorative element -->
    <Rectangle fill="#1a1614" height="600" width="500" arcWidth="16" arcHeight="16" />

    <VBox alignment="CENTER" spacing="0" maxWidth="440" maxHeight="600">
        <padding><Insets top="50" bottom="50" left="50" right="50"/></padding>

        <!-- Logo / Title -->
        <Label styleClass="login-title" text="Scholar's Sanctum" />
        <Region prefHeight="8" />
        <Label styleClass="login-subtitle" text="Enter the Sanctum — prove your worth." />
        <Region prefHeight="40" />

        <!-- Student ID -->
        <Label styleClass="login-label" text="Student ID" />
        <Region prefHeight="6" />
        <TextField fx:id="studentIdField" styleClass="login-field" promptText="e.g. S101"
                   maxWidth="1.7976931348623157E308" />
        <Region prefHeight="20" />

        <!-- Password -->
        <Label styleClass="login-label" text="Password" />
        <Region prefHeight="6" />
        <PasswordField fx:id="passwordField" styleClass="login-field" promptText="Your secret key"
                       maxWidth="1.7976931348623157E308" />
        <Region prefHeight="30" />

        <!-- Error label -->
        <Label fx:id="errorLabel" style="-fx-text-fill: #e66777; -fx-font-size: 12px;" text="" />
        <Region prefHeight="10" />

        <!-- Login button -->
        <Button fx:id="loginButton" text="Enter the Sanctum" styleClass="login-button"
                maxWidth="1.7976931348623157E308" onAction="#handleLogin" mnemonicParsing="false" />

        <Region prefHeight="30" />
        <Label style="-fx-text-fill: #8b847a; -fx-font-size: 11px;" text="Scholar's Sanctum — Student Tracker v1.0" />
    </VBox>
</StackPane>
