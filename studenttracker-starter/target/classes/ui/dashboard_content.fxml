<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" stylesheets="@../css/dashboard.css"
            style="-fx-background-color: transparent; -fx-background: #13110E;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="studenttracker.controller.DashboardController">
    <content>
        <VBox spacing="30">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <!-- Header -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="SANCTUM OVERVIEW" />
                <Label styleClass="title-fantasy" text="The Home Keep" />
                <Label styleClass="subtitle-fantasy" text="A calm command center for honor, presence, and the quests ahead — fed by your ledger." />
            </VBox>

            <!-- Stat Cards Row -->
            <HBox spacing="20">
                <!-- GPA -->
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <ImageView fx:id="iconGpa" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="HONOR (GPA)" />
                    </HBox>
                    <Label fx:id="gpaLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Weighted across enrolled credits" />
                </VBox>
                <!-- Presence -->
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <ImageView fx:id="iconPresence" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="PRESENCE RATE" />
                    </HBox>
                    <Label fx:id="presenceLabel" styleClass="stat-value" text="—" />
                    <Label fx:id="presenceHint" styleClass="stat-label" text="" />
                </VBox>
                <!-- Active Quests -->
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <ImageView fx:id="iconQuests" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="ACTIVE QUESTS" />
                    </HBox>
                    <Label fx:id="questsLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Spring 2026" />
                </VBox>
                <!-- Dark Omens -->
                <VBox spacing="8" styleClass="card-omen" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <ImageView fx:id="iconOmens" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #e66777; -fx-font-weight: 600;" text="DARK OMENS" />
                    </HBox>
                    <Label fx:id="omensLabel" styleClass="omen-value" text="0" />
                    <Label styleClass="omen-label" text="Courses at or above 3 absences" />
                </VBox>
            </HBox>

            <!-- Bottom Row: Recent Scores + Side Panel -->
            <HBox spacing="30">
                <!-- Recent Battle Scores -->
                <VBox spacing="15" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="RECENT BATTLE SCORES" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #8b847a; -fx-font-size: 11px; -fx-cursor: hand;" text="View all →" />
                    </HBox>
                    <VBox fx:id="recentGradesBox" spacing="10" />
                </VBox>

                <!-- Right column -->
                <VBox prefWidth="300" spacing="25">
                    <!-- Dark Omens detail -->
                    <VBox spacing="12" styleClass="card">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="DARK OMENS" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label style="-fx-text-fill: #8b847a; -fx-font-size: 11px; -fx-cursor: hand;" text="View →" />
                        </HBox>
                        <VBox fx:id="omensDetailBox" spacing="8" />
                    </VBox>

                    <!-- Spells & Actions -->
                    <VBox spacing="12">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="SPELLS &amp; ACTIONS" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="  Forge report scroll">
                            <graphic><ImageView fx:id="iconForge" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                        </Button>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="  View all grades">
                            <graphic><ImageView fx:id="iconViewGrades" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                        </Button>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="  Check attendance">
                            <graphic><ImageView fx:id="iconCheckAtt" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                        </Button>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="action-button" text="  Consult the Oracle">
                            <graphic><ImageView fx:id="iconOracle" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                        </Button>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
