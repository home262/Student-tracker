<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="root" stylesheets="@../css/dashboard.css"
            style="-fx-background-color: transparent; -fx-background: #13110E;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="studenttracker.controller.CoursesController">
    <content>
        <VBox spacing="30">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <!-- Header -->
            <VBox spacing="5">
                <Label styleClass="header-label" text="THE CODEX" />
                <Label styleClass="title-fantasy" text="Active Quests" />
                <Label styleClass="subtitle-fantasy" text="All courses bound to your ledger this semester." />
            </VBox>

            <!-- Stats -->
            <HBox spacing="20">
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="ENROLLED QUESTS" />
                    <Label fx:id="enrolledCountLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Total courses" />
                </VBox>
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="CREDIT HOURS" />
                    <Label fx:id="creditHoursLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="This semester" />
                </VBox>
            </HBox>

            <!-- Courses Table -->
            <VBox spacing="15" styleClass="card">
                <Label styleClass="header-label" text="QUEST REGISTRY" />

                <TableView fx:id="coursesTable"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;"
                           VBox.vgrow="ALWAYS" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="idCol" text="Course ID" prefWidth="100" />
                        <TableColumn fx:id="nameCol" text="Quest Name" prefWidth="250" />
                        <TableColumn fx:id="instructorCol" text="Instructor / Sage" prefWidth="200" />
                        <TableColumn fx:id="creditsCol" text="Credits" prefWidth="80" />
                        <TableColumn fx:id="semesterCol" text="Semester" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
