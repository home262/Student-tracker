<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="root" stylesheets="@../css/dashboard.css"
            style="-fx-background-color: transparent; -fx-background: #13110E;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="studenttracker.controller.GradesController">
    <content>
        <VBox spacing="30">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <!-- Header -->
            <VBox spacing="5">
                <Label styleClass="header-label" text="THE CODEX" />
                <Label styleClass="title-fantasy" text="Battle Scores" />
                <Label styleClass="subtitle-fantasy" text="Your grades across all active quests — every score shapes your honor." />
            </VBox>

            <!-- Summary Stat Cards -->
            <HBox spacing="20">
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="SEMESTER GPA" />
                    <Label fx:id="semGpaLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Current semester" />
                </VBox>
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="HIGHEST SCORE" />
                    <Label fx:id="highScoreLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Best battle" />
                </VBox>
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="LOWEST SCORE" />
                    <Label fx:id="lowScoreLabel" styleClass="stat-value" style="-fx-text-fill: #e66777;" text="—" />
                    <Label styleClass="stat-label" text="Needs attention" />
                </VBox>
                <VBox prefWidth="200" spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="header-label" text="COURSES" />
                    <Label fx:id="courseCountLabel" styleClass="stat-value" text="—" />
                    <Label styleClass="stat-label" text="Active quests" />
                </VBox>
            </HBox>

            <!-- Grades Table -->
            <VBox spacing="15" styleClass="card">
                <Label styleClass="header-label" text="ALL BATTLE SCORES" />

                <TableView fx:id="gradesTable"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;"
                           VBox.vgrow="ALWAYS" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="courseCol" text="Course / Quest" prefWidth="250"
                                     style="-fx-text-fill: #a8a29e;" />
                        <TableColumn fx:id="instructorCol" text="Instructor" prefWidth="180"
                                     style="-fx-text-fill: #a8a29e;" />
                        <TableColumn fx:id="scoreCol" text="Score %" prefWidth="100"
                                     style="-fx-text-fill: #a8a29e;" />
                        <TableColumn fx:id="letterCol" text="Grade" prefWidth="80"
                                     style="-fx-text-fill: #a8a29e;" />
                        <TableColumn fx:id="semesterCol" text="Semester" prefWidth="120"
                                     style="-fx-text-fill: #a8a29e;" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
