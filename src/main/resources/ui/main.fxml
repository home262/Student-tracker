<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane styleClass="root" stylesheets="@../css/dashboard.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="studenttracker.controller.MainController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="250" styleClass="sidebar" fx:id="sidebar">
            <children>
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets left="18" top="15" right="10" bottom="5"/></padding>
                    <ImageView fx:id="logoIcon" fitHeight="30" fitWidth="30" pickOnBounds="true" preserveRatio="true" />
                    <VBox spacing="2">
                        <Label wrapText="true"
                               maxWidth="90"
                               style="-fx-font-family: 'Cinzel'; -fx-font-weight: 700; -fx-font-size: 17px; -fx-text-fill: white; -fx-line-spacing: -3;"
                               text="Scholar's&#10;Sanctum" />
                        <Label style="-fx-font-family: 'Cinzel'; -fx-font-size: 10px; -fx-text-fill: #8b847a;" text="Spring Semester 2026" />
                    </VBox>
                </HBox>

                <Region prefHeight="25" />

                <!-- Main Nav -->
                <Label style="-fx-padding: 0 0 8 20; -fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="THE CODEX" />

                <Button fx:id="navHomeKeep" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button, nav-button-active" text="  Home Keep" onAction="#showDashboard">
                    <graphic><ImageView fx:id="iconHome" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>
                <Button fx:id="navGrades" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button" text="  Grades" onAction="#showGrades">
                    <graphic><ImageView fx:id="iconGrades" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>
                <Button fx:id="navCourses" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button" text="  Courses" onAction="#showCourses">
                    <graphic><ImageView fx:id="iconCourses" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>
                <Button fx:id="navAttendance" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button" text="  Attendance" onAction="#showAttendance">
                    <graphic><ImageView fx:id="iconAttendance" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>
                <Button fx:id="navReports" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button" text="  Reports" onAction="#showReports">
                    <graphic><ImageView fx:id="iconReports" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>

                <Region prefHeight="25" />

                <!-- Arsenal Nav -->
                <Label style="-fx-padding: 0 0 8 20; -fx-font-size: 10px; -fx-text-fill: #6b645c; -fx-font-weight: 600;" text="ARSENAL" />

                <Button fx:id="navExport" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button" text="  Export CSV" onAction="#handleExport">
                    <graphic><ImageView fx:id="iconExport" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>
                <Button fx:id="navAdvisor" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button" text="  AI Advisor" onAction="#showAdvisor">
                    <graphic><ImageView fx:id="iconAdvisor" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Logout Button -->
                <Button fx:id="navLogout" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        styleClass="nav-button-logout" text="  Logout" onAction="#handleLogout">
                    <graphic><ImageView fx:id="iconLogout" fitHeight="16" fitWidth="16" pickOnBounds="true" preserveRatio="true" /></graphic>
                </Button>

                <!-- Profile -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="profile-section">
                    <StackPane prefHeight="40" prefWidth="40">
                        <Circle fx:id="avatarCircle" fill="#4b3d75" radius="20" stroke="TRANSPARENT" />
                        <Label fx:id="avatarLetter" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="Y" />
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label fx:id="profileName" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;" text="Student Name" />
                        <Label fx:id="profileRank" style="-fx-font-size: 10px; -fx-text-fill: #8b847a;" text="Scholar rank · Steady" />
                    </VBox>
                </HBox>
            </children>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA - swapped dynamically -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #13110E;" />
    </center>
</BorderPane>
